FoamFile
{
    format      ascii;
    class       dictionary;
    location    "constant";
    object      thermophysicalProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

thermoType
{
    type            heRhoThermo;
    mixture         pureMixture;
    transport       const;
    thermo          hConst;
    equationOfState rhoConst;
    specie          specie;
    energy          sensibleEnthalpy;
}

pRef            100000;

mixture
{
    specie
    {
        molWeight       28.9;
    }
    equationOfState
    {
        rho             0.922;     // [kg/m^3]
    }
    thermodynamics
    {
        Cp              1009;
        Hf              0;
    }
    transport
    {
        mu              6.14667e-05;
        Pr              0.7;
    }
}


