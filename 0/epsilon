FoamFile
{
    format      ascii;
    class       volScalarField;
    location    "0";
    object      epsilon;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 2 -3 0 0 0 0];

internalField   uniform 3.449933e-5;

boundaryField
{
    inlet
    {
        type            fixedValue;
        value           uniform 3.449933e-5;
    }
    outlet
    {
        type            zeroGradient;
    }
    leftup
    {
        type            epsilonWallFunction;
        value           uniform 3.449933e-5;
    }
    leftdown
    {
        type            epsilonWallFunction;
        value           uniform 3.449933e-5;
    }
    top
    {
        type            zeroGradient;
    }
    bottom
    {
        type            epsilonWallFunction;
        value           uniform 3.449933e-5;
    }
    frontAndBack
    {
        type            empty;
    }
}
