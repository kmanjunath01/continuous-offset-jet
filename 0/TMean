internalField   uniform 298;

boundaryField
{
    inlet
    {
        type            calculated;
        value           uniform 385.15;
    }
    leftup
    {
        type            calculated;
        value           uniform 298;
    }
    leftdown
    {
        type            calculated;
        value           uniform 298;
    }
    outlet
    {
        type            calculated;
        value           uniform 298;
    }
    top
    {
        type            calculated;
        value           uniform 298;
    }
    bottom
    {
        type            calculated;
        value           uniform 298;
    }
    frontAndBack
    {
        type            empty;
    }
}


